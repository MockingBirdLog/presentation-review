# .env.example — 環境変数テンプレート
# このファイルはリポジトリに含まれます。
# 実際の値は .env.local（ローカル開発）または Vercel ダッシュボード（本番）で設定してください。

# ==============================
# Supabase
# ==============================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==============================
# Stripe
# ==============================
STRIPE_SECRET_KEY=sk_test_... または sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_10_INTRO=price_...
STRIPE_PRICE_10=price_...
STRIPE_PRICE_25=price_...
STRIPE_PRICE_100=price_...
STRIPE_PRICE_300=price_...

# ==============================
# アプリの URL
# ==============================
# 開発中: http://localhost:3000
# 本番: https://presentation-review.com (または Vercel のドメイン)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ==============================
# Resend（メール送信）
# ==============================
RESEND_API_KEY=re_...

# ==============================
# 管理者
# ==============================
NEXT_PUBLIC_ADMIN_EMAIL=your-email@example.com
